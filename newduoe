-- VISUAL PLACEMENT SYSTEM
-- ========================

local placing = false
local previewPet = nil

local function createPreview(petName)
	local original = PetsFolder:FindFirstChild(petName)
	if not original then
		Status.Text = "[ERROR] Pet not found!"
		return
	end
	
	local clone = original:Clone()
	
	for _, part in pairs(clone:GetDescendants()) do
		if part:IsA("BasePart") then
			part.Transparency = 0.5
			part.CanCollide = false
			part.Color = Color3.fromRGB(0,255,0)
		end
	end
	
	clone.Parent = workspace
	return clone
end

local function updatePreview()
	if previewPet and previewPet.PrimaryPart then
		local hit = mouse.Hit
		previewPet:SetPrimaryPartCFrame(
			CFrame.new(hit.Position.X, hit.Position.Y, hit.Position.Z)
		)
	end
end

DupBtn.MouseButton1Click:Connect(function()
	if placing then return end
	
	Status.Text = "[SYSTEM] Click to place pet"
	previewPet = createPreview(selectedPetName)
	
	if previewPet then
		placing = true
	end
end)

RunService.RenderStepped:Connect(function()
	if placing then
		updatePreview()
	end
end)

mouse.Button1Down:Connect(function()
	if placing and previewPet then
		
		for _, part in pairs(previewPet:GetDescendants()) do
			if part:IsA("BasePart") then
				part.Transparency = 0
				part.CanCollide = true
			end
		end
		
		Status.Text = "[SUCCESS] Pet Placed!"
		placing = false
		previewPet = nil
	end
end)

Close.MouseButton1Click:Connect(function()
	ScreenGui:Destroy()
end)

